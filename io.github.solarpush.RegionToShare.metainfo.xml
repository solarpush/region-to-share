<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
	<id>
		io.github.solarpush.RegionToShare
	</id>
	<name>
		Region to Share
	</name>
	<summary>
		Share a selected screen region in video calls
	</summary>
	<metadata_license>
		CC0-1.0
	</metadata_license>
	<project_license>
		MIT
	</project_license>
	<developer id="io.github.solarpush">
		<name>
			solarpush
		</name>
	</developer>
	<description>
		<p>
			Region-to-Share lets you select a specific area of your screen and display it
			in a dedicated window that you can share directly in video conferencing
			applications such as Google Meet, Teams, Discord, or Zoom.
		</p>
		<p>
			This is especially useful for ultra-wide (21:9, 32:9) or multi-monitor setups
			where sharing the full screen would expose too much, or where you only want to
			share one application region without switching windows.
		</p>
		<p>
			Features:
		</p>
		<ul>
			<li>
				Interactive region selection with real-time preview
			</li>
			<li>
				High-performance real-time display (native Rust, low CPU usage)
			</li>
			<li>
				Native Wayland support via XDG Desktop Portal / PipeWire
			</li>
			<li>
				Native X11 support
			</li>
			<li>
				Modern egui interface
			</li>
			<li>
				Adjustable window opacity
			</li>
			<li>
				Performance monitoring overlay
			</li>
			<li>
				Remembers last selected region
			</li>
		</ul>
	</description>
